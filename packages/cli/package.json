{
  "name": "@aleph/cli",
  "version": "0.3.0",
  "description": "Aleph Protocol CLI — keygen, run a node/registry, resolve and invoke from the terminal.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Leonardo Corte and the Aleph Protocol contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leonardo-Corte/aleph-protocol.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "aleph": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@aleph/core": "workspace:*",
    "@aleph/client": "workspace:*",
    "@aleph/node": "workspace:*",
    "@aleph/registry": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "true",
    "test:coverage": "true",
    "clean": "rm -rf dist"
  }
}
