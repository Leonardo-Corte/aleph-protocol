{
  "name": "@aleph/node",
  "version": "0.3.0",
  "description": "Aleph Protocol node runtime — a capability provider: publishes a Manifest, verifies grants, validates schema, settles, and returns signed receipts.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Leonardo Corte and the Aleph Protocol contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leonardo-Corte/aleph-protocol.git",
    "directory": "packages/node"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@aleph/core": "workspace:*",
    "@aleph/transport": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "true",
    "test:coverage": "true",
    "clean": "rm -rf dist"
  }
}
