{
  "name": "@aleph/settle-evm",
  "version": "0.2.0",
  "description": "Aleph on-chain settlement rail: an EVM escrow (AlephEscrow) settling a stablecoin, via viem. Trustless PAY backing settlement-based reputation.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Leonardo Corte and the Aleph Protocol contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leonardo-Corte/aleph-protocol.git",
    "directory": "packages/settle-evm"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@aleph/core": "workspace:*",
    "viem": "^2.21.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "true",
    "test:coverage": "true",
    "clean": "rm -rf dist",
    "gen:abi": "node scripts/gen-abi.mjs"
  }
}
