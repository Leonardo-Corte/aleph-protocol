{
  "name": "@aleph/mcp",
  "version": "0.2.0",
  "description": "Aleph Protocol MCP server — exposes Aleph to any MCP-capable agent as aleph_resolve and aleph_invoke tools.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Leonardo Corte and the Aleph Protocol contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leonardo-Corte/aleph-protocol.git",
    "directory": "packages/mcp"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "aleph-mcp": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@aleph/core": "workspace:*",
    "@aleph/client": "workspace:*",
    "@aleph/settle-evm": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "true",
    "test:coverage": "true",
    "clean": "rm -rf dist"
  }
}
