{
  "name": "@aleph/transport",
  "version": "0.2.0",
  "private": true,
  "description": "Internal: tiny node:http helpers shared by the node and registry runtimes.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
