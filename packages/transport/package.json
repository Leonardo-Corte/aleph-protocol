{
  "name": "@aleph/transport",
  "version": "0.2.0",
  "description": "Aleph Protocol transport — node:http helpers + observability (logger, metrics, trace) shared by the node and registry runtimes.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Leonardo Corte and the Aleph Protocol contributors",
  "homepage": "https://github.com/Leonardo-Corte/aleph-protocol/tree/main/packages/transport",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leonardo-Corte/aleph-protocol.git",
    "directory": "packages/transport"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "true",
    "test:coverage": "true",
    "clean": "rm -rf dist"
  }
}
